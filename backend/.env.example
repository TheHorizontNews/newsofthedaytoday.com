# Google Search Console (опционально)
GOOGLE_SEARCH_CONSOLE_CREDENTIALS="/path/to/credentials.json"
GSC_MOCK_MODE="true"

# Настройки JWT
ACCESS_TOKEN_EXPIRE_MINUTES=43200
